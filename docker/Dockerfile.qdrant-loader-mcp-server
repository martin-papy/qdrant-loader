FROM python:3.12-slim

WORKDIR /qdrant-loader-mcp-server

RUN useradd --create-home --uid 10001 appuser \
    && chown -R appuser:appuser /qdrant-loader-mcp-server
USER appuser

ENV PYTHONUNBUFFERED=1
ENV PYTHONDONTWRITEBYTECODE=1

ARG QDRANT_LOADER_MCP_SERVER_VERSION=latest

RUN if [ "$QDRANT_LOADER_MCP_SERVER_VERSION" = "latest" ]; then \
       pip install --no-cache-dir qdrant-loader-mcp-server; \
     else \
       pip install --no-cache-dir "qdrant-loader-mcp-server==${QDRANT_LOADER_MCP_SERVER_VERSION}"; \
     fi

ENV PATH=$PATH:/home/appuser/.local/bin

EXPOSE 8080

CMD ["mcp-qdrant-loader", "--transport", "http", "--host", "0.0.0.0", "--port", "8080"]
