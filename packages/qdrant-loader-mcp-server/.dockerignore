# ============================================================================
# QDRANT-LOADER-MCP-SERVER PACKAGE .dockerignore
# Optimized for minimal build context and maximum caching efficiency
# ============================================================================

# ============================================================================
# PYTHON RUNTIME & BUILD ARTIFACTS
# ============================================================================
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# ============================================================================
# VIRTUAL ENVIRONMENTS & DEPENDENCIES
# ============================================================================
venv/
env/
ENV/
.venv/
.env/
.conda/
site-packages/

# ============================================================================
# TESTING & QUALITY ASSURANCE
# ============================================================================
.pytest_cache/
.coverage
htmlcov/
.tox/
.cache
nosetests.xml
coverage.xml
*.cover
.hypothesis/
.nox/
.coverage.*
pytest.ini
tox.ini
.mypy_cache/
.dmypy.json
dmypy.json

# ============================================================================
# IDE & EDITOR CONFIGURATIONS
# ============================================================================
.vscode/
.idea/
*.swp
*.swo
*~
.vim/
.emacs.d/
.sublime-*
*.sublime-*

# ============================================================================
# OPERATING SYSTEM ARTIFACTS
# ============================================================================
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini
$RECYCLE.BIN/

# ============================================================================
# LOGS & TEMPORARY FILES
# ============================================================================
*.log
logs/
tmp/
temp/
*.tmp
*.temp
*.pid
*.seed
*.pid.lock

# ============================================================================
# DATA & RUNTIME DIRECTORIES
# ============================================================================
data/
config/
.taskmaster/
metrics/

# ============================================================================
# JUPYTER & NOTEBOOK FILES
# ============================================================================
.ipynb_checkpoints
*.ipynb

# ============================================================================
# DOCUMENTATION (selective inclusion)
# ============================================================================
docs/
website/
*.md
!README.md
!CONTRIBUTING.md
!LICENSE.md

# ============================================================================
# DEVELOPMENT & BUILD TOOLS
# ============================================================================
tests/
.github/
Makefile
docker-compose.yml
docker-compose.*.yml
.dockerignore
Dockerfile*
.pre-commit-config.yaml
.editorconfig
.flake8
.pylintrc

# ============================================================================
# PACKAGE MANAGEMENT FILES
# ============================================================================
requirements*.txt
setup.py
setup.cfg
poetry.lock
Pipfile
Pipfile.lock

# ============================================================================
# VERSION CONTROL
# ============================================================================
.git/
.gitignore
.gitattributes
.gitmodules

# ============================================================================
# ENVIRONMENT & SECRETS
# ============================================================================
.env*
!.env.template
!.env.example
*.key
*.pem
*.crt
*.csr
secrets/
.secrets/

# ============================================================================
# PERFORMANCE & PROFILING
# ============================================================================
*.prof
*.profile
profile.out
profile.svg
.prof/

# ============================================================================
# BACKUP & WORKSPACE FILES
# ============================================================================
*.bak
*.backup
*.old
*.orig
*.rej
*~
.#*
#*#
*.code-workspace
.cursor/
.cursorignore

# ============================================================================
# PACKAGE-SPECIFIC EXCLUSIONS
# ============================================================================
# Exclude other packages from this build context
../qdrant-loader/
../../tests/
../../docs/
../../website/
../../.github/
../../release.py
../../RELEASE_NOTES.md 