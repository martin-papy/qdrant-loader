# SECURITY: Copy this file to .env and fill in your actual values.
# Never commit .env with real secrets to version control.
# Ensure .env is listed in .gitignore (it is by default).

# QDrant Configuration
# Leave empty for local/no-auth Qdrant. Set a real key for Qdrant Cloud.
QDRANT_API_KEY=""
QDRANT_COLLECTION_NAME=my_docs
QDRANT_URL=http://localhost:6333


# =========================
# LLM Configuration (Unified, Ollama-first)
# =========================

# Set to "openai" for OpenAI deployments.
LLM_PROVIDER="ollama"
# Possible values:
#   - ollama (default, local)
#   - openai (cloud)

LLM_BASE_URL=http://localhost:11434/v1
# Ollama: Local OpenAI-compatible endpoint
# OpenAI equivalent: https://api.openai.com/v1

LLM_API_KEY=ollama
# Ollama: Always use "ollama" (no authentication required)
# OpenAI: Use your real API key (e.g. sk-xxxx)


LLM_EMBEDDING_MODEL=argus-ai/pplx-embed-v1-0.6b:fp32
# Ollama: Local embedding model
# OpenAI equivalent:
#   - text-embedding-3-small (1536 dims)


LLM_CHAT_MODEL=llama3.1:8b
# Ollama: Local chat / instruction model
# OpenAI equivalent:
#   - gpt-4o
#   - gpt-4o-mini

VECTOR_SIZE=1024
# OpenAI: 1536

# Legacy (still supported)
OPENAI_API_KEY=your_openai_key
# Used by OpenAI flows and as a fallback in some conversion paths
# (e.g., MarkItDown LLM descriptions) when explicit llm_api_key is not set.

# State Management
STATE_DB_PATH=./state.db

# Git Authentication Configuration
# GitHub Personal Access Token for repository access
REPO_TOKEN=your_github_token_here

# Confluence Configuration
# For Confluence Cloud (*.atlassian.net)
CONFLUENCE_TOKEN=your_confluence_token_here
CONFLUENCE_EMAIL=your_confluence_email_here

# For Confluence Data Center/Server
# Personal Access Token (alternative to token/email for Data Center)
# Generate at: Confluence → Profile → Settings → Personal Access Tokens
CONFLUENCE_PAT=your_confluence_personal_access_token_here

# Jira Configuration
# For Jira Cloud (*.atlassian.net)
JIRA_TOKEN=your_jira_token_here
JIRA_EMAIL=your_jira_email_here

# For Jira Data Center/Server
# Personal Access Token (alternative to token/email for Data Center)
# Generate at: Jira → Profile → Settings → Personal Access Tokens
JIRA_PAT=your_jira_personal_access_token_here

# MCP Server Configuration (for qdrant-loader-mcp-server)
# Log level for MCP server (DEBUG, INFO, WARNING, ERROR, CRITICAL)
MCP_LOG_LEVEL=INFO
# Path to MCP log file (recommended for debugging)
MCP_LOG_FILE=path/to/your/mcp/logs/mcp.log
# Disable console logging (recommended: true for Cursor integration)
MCP_DISABLE_CONSOLE_LOGGING=true

# Optional: Used for the release script
GITHUB_TOKEN=your_github_token_here