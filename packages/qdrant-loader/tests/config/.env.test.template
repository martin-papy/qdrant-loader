# Test Environment Variables Template
# Copy this file to .env and customize it for your test environment
# These variables are used by the test configuration templates

# =============================================================================
# CORE SERVICES - Required for basic functionality
# =============================================================================

# OpenAI Configuration (Primary embedding service for tests)
OPENAI_API_KEY=your_openai_api_key_here

# QDrant Configuration (Vector database for tests)
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=  # Leave empty for local QDrant instances
QDRANT_COLLECTION_NAME=test_collection

# =============================================================================
# EMBEDDING SERVICE CONFIGURATION
# =============================================================================

# Embedding Provider Settings
EMBEDDING_PROVIDER=openai
EMBEDDING_ENDPOINT=https://api.openai.com/v1
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_TOKENIZER=cl100k_base
EMBEDDING_VECTOR_SIZE=1536
EMBEDDING_API_KEY=your_openai_api_key_here

# =============================================================================
# NEO4J CONFIGURATION (Optional - for Graphiti features)
# =============================================================================

# Neo4j Database Configuration
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=test-password
NEO4J_DATABASE=neo4j

# =============================================================================
# GRAPHITI CONFIGURATION (Optional - for knowledge graph features)
# =============================================================================

# Graphiti LLM Configuration
GRAPHITI_LLM_PROVIDER=openai
GRAPHITI_LLM_MODEL=gpt-4o-mini
GRAPHITI_LLM_API_KEY=your_openai_api_key_here
GRAPHITI_LLM_ENDPOINT=https://api.openai.com/v1

# Graphiti Embedder Configuration
GRAPHITI_EMBEDDER_PROVIDER=openai
GRAPHITI_EMBEDDER_MODEL=text-embedding-3-small
GRAPHITI_EMBEDDER_API_KEY=your_openai_api_key_here
GRAPHITI_EMBEDDER_ENDPOINT=https://api.openai.com/v1

# =============================================================================
# FILE CONVERSION CONFIGURATION (Optional - for file conversion tests)
# =============================================================================

# MarkItDown LLM Configuration (for image descriptions)
MARKITDOWN_LLM_MODEL=gpt-4o-mini
MARKITDOWN_LLM_ENDPOINT=https://api.openai.com/v1
MARKITDOWN_LLM_API_KEY=your_openai_api_key_here

# =============================================================================
# STATE MANAGEMENT CONFIGURATION
# =============================================================================

# State Database Configuration
STATE_DB_PATH=:memory:  # Use in-memory database for tests

# =============================================================================
# VALIDATION ENGINE CONFIGURATION
# =============================================================================

SMTP_SERVER=localhost
NOTIFICATION_FROM_EMAIL=notif@localhost
ADMIN_EMAIL=admin@localhost
SLACK_WEBHOOK_URL=None
WEBHOOK_ENDPOINT=None
WEBHOOK_TOKEN=None
MANAGER_EMAIL=manager@localhost
DIRECTOR_EMAIL=director@localhost

# =============================================================================
# TEST DATA SOURCES
# =============================================================================

# GitHub Personal Access Token (Legacy)
REPO_URL=https://github.com/your-username/your-repo.git
REPO_TOKEN=your_github_token_here

# Confluence Legacy Variables
CONFLUENCE_URL=https://your-domain.atlassian.net/wiki
CONFLUENCE_SPACE_KEY=TEST
CONFLUENCE_TOKEN=your_confluence_token_here
CONFLUENCE_EMAIL=your_confluence_email_here


# JIRA Legacy Variables
JIRA_URL=https://your-domain.atlassian.net
JIRA_PROJECT_KEY=TEST
JIRA_TOKEN=your_jira_token_here
JIRA_EMAIL=your_jira_email_here