# =============================================================================
# Environment Variables Template for QDrant Loader
# =============================================================================
# Copy this file to .env and customize it for your needs
# These variables are referenced in connectivity.yaml, projects.yaml, and fine-tuning.yaml
# 
# Configuration Structure:
# - connectivity.yaml: Database connections, LLM providers, authentication
# - projects.yaml: Project definitions and data source configurations  
# - fine-tuning.yaml: Processing parameters and performance settings
# =============================================================================

# -----------------------------------------------------------------------------
# CONNECTIVITY CONFIGURATION (connectivity.yaml)
# -----------------------------------------------------------------------------

# Embedding Service Configuration
OPENAI_API_KEY=your_openai_api_key_here

# QDrant Vector Database (if using QDrant Cloud)
QDRANT_API_KEY=your_qdrant_api_key_here

# Neo4j Graph Database (required only when Graphiti is enabled)
NEO4J_PASSWORD=your_neo4j_password_here

# Graphiti Knowledge Graph Configuration
GRAPHITI_LLM_API_KEY=your_graphiti_llm_api_key_here
GRAPHITI_EMBEDDER_API_KEY=your_graphiti_embedder_api_key_here

# State Management Database
STATE_DB_PATH=./state.db

# -----------------------------------------------------------------------------
# PROJECTS CONFIGURATION (projects.yaml)
# -----------------------------------------------------------------------------

# Git Repository Authentication
GITHUB_TOKEN=your_github_token_here
GITLAB_TOKEN=your_gitlab_token_here
BITBUCKET_TOKEN=your_bitbucket_token_here
DOCS_REPO_TOKEN=your_docs_repo_token_here
CODE_REPO_TOKEN=your_code_repo_token_here

# Confluence Configuration
# For Confluence Cloud (*.atlassian.net)
CONFLUENCE_TOKEN=your_confluence_token_here
CONFLUENCE_EMAIL=your_confluence_email_here
CONFLUENCE_SPACE_KEY=your_confluence_space_key_here

# For Confluence Data Center/Server
CONFLUENCE_DC_TOKEN=your_confluence_datacenter_pat_here
CONFLUENCE_DC_SPACE_KEY=your_confluence_datacenter_space_key_here

# JIRA Configuration  
# For JIRA Cloud (*.atlassian.net)
JIRA_TOKEN=your_jira_token_here
JIRA_EMAIL=your_jira_email_here
JIRA_PROJECT_KEY=your_jira_project_key_here

# For JIRA Data Center/Server
JIRA_DC_TOKEN=your_jira_datacenter_pat_here
JIRA_DC_PROJECT_KEY=your_jira_datacenter_project_key_here

# Optional: Used for the release script
# If you are contributing to the project
# you can use your own token here
GITHUB_TOKEN=your_github_token_here