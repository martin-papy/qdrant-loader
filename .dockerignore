# Root-level .dockerignore for qdrant-loader workspace
# This file optimizes build context for workspace-wide Docker builds

# ============================================================================
# DEVELOPMENT ENVIRONMENTS & VIRTUAL ENVIRONMENTS
# ============================================================================
venv/
env/
ENV/
.venv/
.env/
.conda/
__pycache__/
*.py[cod]
*$py.class
*.so

# ============================================================================
# PYTHON BUILD ARTIFACTS
# ============================================================================
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST
.Python

# ============================================================================
# TESTING & COVERAGE
# ============================================================================
.pytest_cache/
.coverage
htmlcov/
.tox/
.cache
nosetests.xml
coverage.xml
*.cover
.hypothesis/
.nox/
.coverage.*
pytest.ini
tox.ini

# ============================================================================
# IDE & EDITOR FILES
# ============================================================================
.vscode/
.idea/
*.swp
*.swo
*~
.vim/
.emacs.d/
.sublime-*
*.sublime-*

# ============================================================================
# OPERATING SYSTEM FILES
# ============================================================================
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini
$RECYCLE.BIN/

# ============================================================================
# LOGS & TEMPORARY FILES
# ============================================================================
*.log
logs/
tmp/
temp/
*.tmp
*.temp
*.pid
*.seed
*.pid.lock

# ============================================================================
# DATA & CONFIGURATION DIRECTORIES
# ============================================================================
data/
config/
.taskmaster/
metrics/
htmlcov/

# ============================================================================
# JUPYTER NOTEBOOKS
# ============================================================================
.ipynb_checkpoints
*.ipynb

# ============================================================================
# DOCUMENTATION (keep essential README files)
# ============================================================================
docs/
website/
*.md
!README.md
!CONTRIBUTING.md
!LICENSE.md

# ============================================================================
# VERSION CONTROL
# ============================================================================
.git/
.gitignore
.gitattributes
.gitmodules

# ============================================================================
# CI/CD & GITHUB
# ============================================================================
.github/
.gitlab-ci.yml
.travis.yml
.circleci/
.jenkins/
Jenkinsfile

# ============================================================================
# DOCKER & CONTAINERIZATION
# ============================================================================
docker-compose.yml
docker-compose.*.yml
.dockerignore
Dockerfile*
.docker/

# ============================================================================
# PACKAGE MANAGEMENT & BUILD TOOLS
# ============================================================================
requirements*.txt
setup.py
setup.cfg
pyproject.toml
poetry.lock
Pipfile
Pipfile.lock
package.json
package-lock.json
yarn.lock
node_modules/

# ============================================================================
# DEVELOPMENT TOOLS & CONFIGURATION
# ============================================================================
Makefile
.pre-commit-config.yaml
.editorconfig
.flake8
.pylintrc
mypy.ini
.mypy_cache/
.dmypy.json
dmypy.json

# ============================================================================
# ENVIRONMENT & SECRETS
# ============================================================================
.env*
!.env.template
!.env.example
*.key
*.pem
*.crt
*.csr
secrets/
.secrets/

# ============================================================================
# RELEASE & DEPLOYMENT
# ============================================================================
release.py
RELEASE_NOTES.md
CHANGELOG.md
*.tar.gz
*.zip
*.deb
*.rpm

# ============================================================================
# WORKSPACE-SPECIFIC EXCLUSIONS
# ============================================================================
qdrant-loader.code-workspace
*.code-workspace
.cursor/
.cursorignore

# ============================================================================
# PERFORMANCE & PROFILING
# ============================================================================
*.prof
*.profile
profile.out
profile.svg
.prof/

# ============================================================================
# BACKUP & TEMPORARY FILES
# ============================================================================
*.bak
*.backup
*.old
*.orig
*.rej
*~
.#*
#*# 