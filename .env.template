# =============================================================================
# QDrant Loader Environment Configuration
# =============================================================================
# Copy this file to .env and customize the values for your environment
# DO NOT commit .env to version control - it contains sensitive information

# =============================================================================
# User Data Directory (mounted into qdrant-loader and qdrant-mcp server containers)
# =============================================================================
USER_DATA_DIR=/path/to/your/user/data

# =============================================================================
# Database Configuration
# =============================================================================

# QDrant Vector Database
QDRANT_URL=http://qdrant:6333
QDRANT__SERVICE__HTTP_PORT=6333
QDRANT__SERVICE__GRPC_PORT=6334

# Neo4j Graph Database
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password123

# Neo4j Memory Configuration (adjust based on your system)
NEO4J_HEAP_INITIAL=512m
NEO4J_HEAP_MAX=2G
NEO4J_PAGECACHE=1G

# =============================================================================
# Application Configuration
# =============================================================================

# MCP Server
MCP_SERVER_PORT=3000

# Python Configuration
PYTHONPATH=/app
PYTHONUNBUFFERED=1
PYTHONDONTWRITEBYTECODE=1

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json

# =============================================================================
# AI/ML API Keys (Required for AI features)
# =============================================================================
# Uncomment and set the API keys you plan to use

# OpenAI API Key (for embeddings and chat)
# OPENAI_API_KEY=sk-your-openai-api-key-here

# Anthropic API Key (for Claude models)
# ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key-here

# Cohere API Key (for embeddings)
# COHERE_API_KEY=your-cohere-api-key-here

# Hugging Face API Key (for models)
# HUGGINGFACE_API_KEY=hf_your-huggingface-api-key-here

# =============================================================================
# Security Configuration
# =============================================================================

# JWT Secret (generate a secure random string)
# JWT_SECRET=your-jwt-secret-here

# API Rate Limiting
# RATE_LIMIT_PER_MINUTE=100

# CORS Origins (comma-separated)
# CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# =============================================================================
# Performance Configuration
# =============================================================================

# Worker Configuration
# WORKER_PROCESSES=4
# WORKER_THREADS=2

# Cache Configuration
# REDIS_URL=redis://localhost:6379
# CACHE_TTL=3600

# Batch Processing
# BATCH_SIZE=100
# MAX_CONCURRENT_REQUESTS=10

# =============================================================================
# Resource Limits (Docker Compose)
# =============================================================================
# These are used in docker-compose.yml for resource constraints
# Adjust based on your system capabilities

# QDrant Resource Limits
# QDRANT_CPU_LIMIT=2.0
# QDRANT_MEMORY_LIMIT=4G
# QDRANT_CPU_RESERVATION=0.5
# QDRANT_MEMORY_RESERVATION=1G

# Neo4j Resource Limits
# NEO4J_CPU_LIMIT=4.0
# NEO4J_MEMORY_LIMIT=6G
# NEO4J_CPU_RESERVATION=1.0
# NEO4J_MEMORY_RESERVATION=2G

# QDrant Loader Resource Limits
# QDRANT_LOADER_CPU_LIMIT=2.0
# QDRANT_LOADER_MEMORY_LIMIT=3G
# QDRANT_LOADER_CPU_RESERVATION=0.5
# QDRANT_LOADER_MEMORY_RESERVATION=512M

# MCP Server Resource Limits
# MCP_SERVER_CPU_LIMIT=1.0
# MCP_SERVER_MEMORY_LIMIT=2G
# MCP_SERVER_CPU_RESERVATION=0.25
# MCP_SERVER_MEMORY_RESERVATION=256M

# =============================================================================
# Development Configuration
# =============================================================================

# Development Mode
# DEBUG=false
# DEVELOPMENT_MODE=false

# Profiling
# ENABLE_PROFILING=false
# PROFILE_OUTPUT_DIR=/app/profiles

# Testing
# TEST_DATABASE_URL=sqlite:///test.db

# =============================================================================
# Monitoring and Observability
# =============================================================================

# Metrics
# ENABLE_METRICS=true
# METRICS_PORT=9090

# Health Checks
# HEALTH_CHECK_INTERVAL=30
# HEALTH_CHECK_TIMEOUT=10

# Tracing
# JAEGER_ENDPOINT=http://jaeger:14268/api/traces
# ENABLE_TRACING=false 